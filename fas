name: Build Betaflight HEX (30min failsafe)

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - name: Install toolchain
      run: |
        sudo apt update
        sudo apt install -y build-essential gcc-arm-none-eabi

    - name: Patch failsafe
      run: |
        sed -i 's/receivingRxDataPeriodPreset = failsafeState.rxDataRecoveryPeriod/receivingRxDataPeriodPreset = 1800000/g' src/main/flight/failsafe.c

    - name: Build
      run: |
        make TARGET=STM32F7X2

    - name: Upload HEX
      uses: actions/upload-artifact@v4
      with:
        name: firmware
        path: obj/main/STM32F7X2/*.hex
